# ── App ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Comma-separated list of allowed CORS origins (use * only in development)
CORS_ORIGINS=*

# ── Database (PostgreSQL + pgvector) ────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=aichat
DATABASE_PASSWORD=aichat
DATABASE_NAME=aichat
DATABASE_SSL=false
# Optional: overrides the discrete fields above when set
# DATABASE_URL=postgres://aichat:aichat@localhost:5432/aichat

# ── Auth (WS-3) ─────────────────────────────────────────────────────
# Secret used to sign access JWTs. A dev default is used when unset so the app
# still boots locally — you MUST set a strong, unique value in production.
JWT_ACCESS_SECRET=
# Access-token lifetime (jsonwebtoken duration string).
JWT_ACCESS_TTL=15m
# Refresh-token lifetime, in days.
REFRESH_TOKEN_TTL_DAYS=30
# bcrypt cost factor for password hashing (4–15).
BCRYPT_ROUNDS=10

# ── S3 / object storage (screenshots, used by WS-5) ─────────────────
S3_REGION=us-east-1
S3_BUCKET=aichat-screenshots
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional: custom endpoint for MinIO / LocalStack
# S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=false

# ── Observability ───────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ── Usage / Quota & tiers (WS-6) ────────────────────────────────────
# Free-tier daily limits. Pro is unlimited on counts (bounded by the spend cap).
USAGE_FREE_REPLIES_PER_DAY=20
USAGE_FREE_SCREENSHOTS_PER_DAY=5
# Per-user daily LLM spend ceiling in USD, bounding abuse on Pro "unlimited".
# Set to "unlimited" (or blank/0) to disable. Free has no cap by default.
USAGE_PRO_DAILY_SPEND_CAP_USD=20
# USAGE_FREE_DAILY_SPEND_CAP_USD=

# ── LLM provider (AI Pipeline, WS-4) ────────────────────────────────
# Decision #1: OpenAI-compatible by default. Leave LLM_PROVIDER unset and the
# app uses `openai` when LLM_API_KEY is present, else the keyless deterministic
# `stub` (local/test). Set explicitly to stub|openai to override (claude|gemini
# are reserved placeholders). Key is supplied via runtime secrets — never commit.
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# OpenAI-compatible proxy/gateway base URL. Unset → https://api.openai.com/v1.
# When set, the OpenAI client is repointed here (stays the `openai` provider).
# LLM_BASE_URL=
# Per-call model overrides; default to gpt-4o-mini when unset.
# LLM_REPLY_MODEL=
# LLM_ANALYSIS_MODEL=
LLM_REQUEST_TIMEOUT_MS=30000
# Bounded JSON-repair retries on model drift before degrading gracefully
LLM_MAX_REPAIR_RETRIES=1

# ── Embeddings (Memory Engine, DAI-146 / MS-1) ──────────────────────
# Reuses the OpenAI credentials above (LLM_API_KEY / LLM_BASE_URL). Leave
# EMBEDDING_PROVIDER unset and the app uses `openai` when LLM_API_KEY is present,
# else the keyless deterministic stub (local/test). Set explicitly to stub|openai.
# EMBEDDING_PROVIDER=openai
# Locked working default: text-embedding-3-small @ 1536 dims, cosine distance.
# Override to text-embedding-3-large (set EMBEDDING_DIMENSIONS=3072) pre-migration;
# the backfill/re-embed job migrates existing rows. EMBEDDING_DIMENSIONS is the N
# that the memories.embedding vector(N) column must match.
# EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
# Falls back to LLM_REQUEST_TIMEOUT_MS when unset.
# EMBEDDING_REQUEST_TIMEOUT_MS=30000

# ── Memory retrieval (MS-3 / DAI-148) ───────────────────────────────
# Set MEMORY_RETRIEVAL_ENABLED=false to fall back to the no-op retriever.
MEMORY_RETRIEVAL_ENABLED=true
MEMORY_RETRIEVAL_TOP_K=5
MEMORY_COSINE_THRESHOLD=0.75
# Approx prompt budget (chars; ≈4 chars/token) for injected memory text.
MEMORY_CONTEXT_CHAR_BUDGET=1200

# ── Memory extraction worker (MS-4 / DAI-149) + Redis ───────────────
# Off by default — the worker needs Redis. docker-compose sets it on.
MEMORY_EXTRACTION_ENABLED=false
# Facts at/above this confidence go `active` (retrievable); below → pending_review.
MEMORY_HIGH_CONFIDENCE_THRESHOLD=0.7
# Cost control (MS-6 §5.10): max new extraction runs per user per UTC day.
MEMORY_EXTRACTION_DAILY_BUDGET=200
REDIS_HOST=localhost
REDIS_PORT=6379
