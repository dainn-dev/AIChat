# ── App ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Comma-separated list of allowed CORS origins (use * only in development)
CORS_ORIGINS=*

# ── Database (PostgreSQL + pgvector) ────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=aichat
DATABASE_PASSWORD=aichat
DATABASE_NAME=aichat
DATABASE_SSL=false
# Optional: overrides the discrete fields above when set
# DATABASE_URL=postgres://aichat:aichat@localhost:5432/aichat

# ── S3 / object storage (screenshots, used by WS-5) ─────────────────
S3_REGION=us-east-1
S3_BUCKET=aichat-screenshots
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional: custom endpoint for MinIO / LocalStack
# S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=false

# ── Observability ───────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ── Usage / Quota & tiers (WS-6) ────────────────────────────────────
# Free-tier daily limits. Pro is unlimited on counts (bounded by the spend cap).
USAGE_FREE_REPLIES_PER_DAY=20
USAGE_FREE_SCREENSHOTS_PER_DAY=5
# Per-user daily LLM spend ceiling in USD, bounding abuse on Pro "unlimited".
# Set to "unlimited" (or blank/0) to disable. Free has no cap by default.
USAGE_PRO_DAILY_SPEND_CAP_USD=20
# USAGE_FREE_DAILY_SPEND_CAP_USD=
